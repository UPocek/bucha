{
  "Template": {
    "TemplateName": "BuchaOrderConfirmation",
    "SubjectPart": "{{subject}}",
    "HtmlPart": "<!DOCTYPE html><html lang=\"{{htmlLang}}\"><head><meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><title>{{title}}</title></head><body style=\"margin: 0; padding: 0; background-color: #ffffff;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"background-color: #ffffff;\"><tr><td align=\"center\" style=\"padding: 20px 0;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"600\" style=\"background-color: #fcfcfc; border-radius: 16px; font-family: Helvetica, Arial, sans-serif; color: #213343;\"><tr><td style=\"padding: 40px 30px;\"><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\"><tr><td width=\"50%\" style=\"font-size: 16px; font-weight: bold;\">{{heading}}</td><td width=\"50%\" style=\"font-size: 16px; text-align: right; padding-right: 20px;\">{{orderDate}}</td></tr></table><h2 style=\"padding-top: 60px; padding-bottom: 60px; font-size: 36px; line-height: 1.1em; margin: 0;\">{{orderId}}</h2><p style=\"color: #F08A6B; padding-bottom: 25px; font-size: 16px; margin: 0;\">{{successMessage}}</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\"><tr><td style=\"font-size: 16px; padding-bottom: 20px;\">{{nameLabel}}: {{userName}}</td></tr><tr><td style=\"font-size: 16px; padding-bottom: 20px;\">{{emailLabel}}: {{userEmail}}</td></tr><tr><td style=\"font-size: 16px; padding-bottom: 20px;\">{{phoneLabel}}: {{userPhone}}</td></tr><tr><td style=\"font-size: 16px; padding-bottom: 20px;\">{{addressLabel}}: {{userAddress}}, {{userPostalCode}} {{userCity}}, {{userCountry}}</td></tr><tr><td style=\"font-size: 16px; padding-bottom: 20px;\">{{noteLabel}}: {{userNote}}</td></tr><tr><td style=\"font-size: 16px; padding-bottom: 20px;\">{{orderLinkLabel}}: <a href=\"{{orderLink}}\">{{orderLink}}</a></td></tr><tr><td style=\"font-size: 16px; padding-bottom: 20px;\">{{totalLabel}}: {{totalPrice}}{{currency}}</td></tr></table><hr /><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"margin-top: 20px; margin-bottom: 20px;\"><tr><td><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\">{{products}}</table></td></tr></table><hr /><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"padding-top: 30px;\"><tr><td width=\"60%\" style=\"font-size: 14px; line-height: 20px; font-weight: bold;\">{{footerText}}</td><td width=\"40%\" align=\"right\"><img src=\"https://static-resources-buchars.s3.eu-central-1.amazonaws.com/bucha_logo.png\" width=\"200\" height=\"55.7\" alt=\"bucha.rs\" style=\"display: block; border: 0;\"></td></tr></table></td></tr></table></td></tr></table></body></html>",
    "TextPart": "{{textPart}}"
  }
}
